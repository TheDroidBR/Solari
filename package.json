{
  "name": "solari",
  "productName": "Solari",
  "version": "1.10.0",
  "description": "Solari - Advanced Discord Rich Presence",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder --win nsis",
    "build:clean": "rmdir /s /q \"Solari - Programa\" 2>nul & npm run build"
  },
  "keywords": [
    "electron",
    "discord",
    "rpc"
  ],
  "author": "TheDroid",
  "license": "GPL-2.0",
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.3",
    "express": "^4.18.0",
    "systeminformation": "^5.31.5",
    "uuid": "^9.0.0",
    "wavesurfer.js": "^7.12.1",
    "ws": "^8.16.0"
  },
  "build": {
    "appId": "com.solari.app",
    "productName": "Solari",
    "publish": [
      {
        "provider": "generic",
        "url": "https://github.com/TheDroidBR/Solari/releases/latest/download",
        "useMultipleRangeRequest": false
      }
    ],
    "directories": {
      "output": "Solari - Programa"
    },
    "files": [
      "src/**/*",
      "package.json",
      "*.png",
      "*.ico"
    ],
    "extraResources": [
      {
        "from": "SolariPhotoTransparente.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "SolariPhotoTransparente.ico",
      "publisherName": "TheDroid",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "artifactName": "Solari-Setup.exe",
      "shortcutName": "Solari"
    },
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "**/discord-rpc/**/*",
      "**/*.dll"
    ],
    "npmRebuild": true,
    "nodeGypRebuild": false
  }
}